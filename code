export default {
  async fetch(request, env) {
    const url = new URL(request.url);
    
    // 例如： /proxy/https://api.target.com/xxx → 代理到目标
    if (url.pathname.startsWith('/proxy/')) {
      const targetUrl = url.pathname.slice(7) + url.search;  // 去掉 /proxy/
      
      // 构建新请求，关键：去掉 Referer 和其他可能暴露的头
      const headers = new Headers(request.headers);
      headers.delete('Referer');        // 关键：移除 Referer
      headers.delete('Origin');
      // headers.set('Referer', '');    // 或者伪造为空/其他值
      // headers.set('User-Agent', 'Mozilla/5.0 ...'); // 可自定义 UA

      const proxyRequest = new Request(targetUrl, {
        method: request.method,
        headers: headers,
        body: request.body,
        redirect: 'follow',
      });

      try {
        const response = await fetch(proxyRequest);
        
        // 复制响应并添加 CORS 支持（前端才能正常访问）
        const newResponse = new Response(response.body, response);
        newResponse.headers.set('Access-Control-Allow-Origin', '*'); // 根据需要调整
        newResponse.headers.set('Access-Control-Allow-Methods', 'GET, POST, OPTIONS');
        newResponse.headers.set('Access-Control-Allow-Headers', '*');
        
        return newResponse;
      } catch (err) {
        return new Response('Proxy Error', { status: 502 });
      }
    }

    // 如果不想走 proxy 路径，也可以返回 404 或 fallback
    return new Response('Not Found', { status: 404 });
  }
};
